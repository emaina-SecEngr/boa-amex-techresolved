# ===============================================================
# LBBS Email Configuration (ConOps 5.6 - Communication Tools)
# ===============================================================
# Set these to enable production email delivery.
# Without SMTP_HOST, all emails log to console (dev mode).

# Option 1: SMTP (Gmail, Outlook, SendGrid SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your-sendgrid-api-key-here
SMTP_FROM=noreply@lifebeyondthebooksaz.org

# Option 2: AWS SES (uncomment and set region)
# AWS_SES_REGION=us-west-2
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

