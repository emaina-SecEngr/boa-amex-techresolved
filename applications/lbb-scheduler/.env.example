# =============================================================
# LBBS Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================

# --- Database ---
DATABASE_URL=postgresql://lbbs_user:your_password_here@localhost:5432/lbbs_db

# --- JWT Authentication ---
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
APP_NAME=Life Beyond the Books Scheduler
APP_ENV=development
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email (SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@lifebeyondthebooksaz.org
EMAIL_FROM_NAME=Life Beyond the Books

# --- Admin Defaults ---
ADMIN_DEFAULT_EMAIL=admin@lifebeyondthebooksaz.org
ADMIN_DEFAULT_PASSWORD=change-this-immediately

# --- Server ---
PORT=8000

